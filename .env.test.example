# Copia este archivo a .env.test y completa las variables.
# .env.test está en .gitignore — NO se commitea.

# Supabase del proyecto AI Smart Content
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<public anon key>

# Service role solo para tests que verifican shape de RPCs sin RLS.
# Si está vacío, esos tests se saltan automáticamente.
SUPABASE_SERVICE_ROLE_KEY=

# Org de pruebas (UUID). Usá una org dedicada — los tests son read-only pero
# llaman RPCs con SECURITY DEFINER que validan membership.
TEST_ORG_ID=a1000000-0000-0000-0000-000000000001

# AI Engine público (Cloudflared tunnel)
AI_ENGINE_URL=https://api.aismartcontent.io
