{
  "name": "ugc-user-profile",
  "version": "1.0.0",
  "description": "Sistema de perfil de usuario con PostgreSQL",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "migrate": "node migrations/migrate.js",
    "seed": "node seeds/seed.js",
    "db:test": "node scripts/test-connection.js",
    "db:populate": "node scripts/populate-fictitious-data.js",
    "db:diagnose": "node scripts/database-diagnostics.js",
    "db:check-relations": "node scripts/check-relationships.js",
    "db:full-check": "npm run db:diagnose && npm run db:check-relations"
  },
  "keywords": [
    "postgresql",
    "user-profile",
    "ugc"
  ],
  "author": "ARDE AGENCY",
