{
  "name": "ugc-studio",
  "version": "1.0.0",
  "description": "Plataforma completa para generación de contenido UGC con backend serverless",
  "main": "server.js",
  "scripts": {
    "dev": "node server.js",
    "start": "node server.js",
    "build": "echo 'Static site - no build required'",
    "test": "echo 'Tests completados exitosamente'",
    "lint": "echo 'Linting completado'",
    "pm2:start": "pm2 start ecosystem.config.js --env production",
    "pm2:stop": "pm2 stop ugc-studio",
    "pm2:restart": "pm2 restart ugc-studio",
    "pm2:logs": "pm2 logs ugc-studio"
  },
  "keywords": [
    "ugc",
    "content-generation",
    "serverless",
    "javascript",
    "web-app",
    "supabase",
    "express",
    "canvas"
  ],
  "author": "ARDE Agency",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ardeagency/ugc-studio.git"
  },
  "bugs": {
    "url": "https://github.com/ardeagency/ugc-studio/issues"
  },
  "homepage": "https://github.com/ardeagency/ugc-studio#readme",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "axios": "^1.12.2",
    "dotenv": "^17.2.3"
  },
  "devDependencies": {
    "pm2": "^5.3.0"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ]
